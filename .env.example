# AftercareOS environment variables. Copy to .env and fill in.

# ── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (DB + Auth) ─────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# When Supabase is not configured, the app runs in MOCK_DATA mode (in-memory store)
# so the full UI is demoable without a database.

# ── Twilio (SMS) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# A messaging service sid OR a default from-number; per-clinic numbers provisioned at onboarding
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

# ── AI (Vercel AI SDK; OpenAI + GLM switchable) ──────
OPENAI_API_KEY=
AI_DEFAULT_PROVIDER=openai   # openai | glm
GLM_BASE_URL=
GLM_API_KEY=

# ── Inngest (scheduler) ──────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_API_BASE=

# ── Square (booking integration, Phase 3) ────────────
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_ENVIRONMENT=sandbox

# ── Stripe (billing, Phase 6) ────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=

# ── Resend (transactional email) ─────────────────────
RESEND_API_KEY=
